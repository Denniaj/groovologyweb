# Supabase (nombres tal cual los crea la integracion de Supabase en Vercel,
# con el prefijo del nombre del proyecto — ver NEXT_PUBLIC_SUPABASE_URL abajo,
# que se agrega aparte porque la original no trae el prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_groovology_SUPABASE_ANON_KEY=
groovology_SUPABASE_SERVICE_ROLE_KEY=

# Resend (correos transaccionales)
RESEND_API_KEY=
EMAIL_FROM="Groovology <noreply@groovology.com>"

# Gemini (analisis de comprobantes SINPE por vision)
GEMINI_API_KEY=

# Cron (app/api/cron/*) — header de autorizacion, comparacion timing-safe
CRON_SECRET=

# URL publica del sitio (usada en correos y metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
